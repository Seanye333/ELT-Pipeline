# ─── Microsoft Graph API / OneDrive ─────────────────────────────────────────
# Azure App Registration → Overview page
GRAPH_TENANT_ID=your-azure-tenant-id
GRAPH_CLIENT_ID=your-app-registration-client-id
GRAPH_CLIENT_SECRET=your-client-secret-value
# User's UPN or Object ID (for /me) — or set GRAPH_DRIVE_ID for shared drives
GRAPH_ONEDRIVE_USER_ID=user@company.com
GRAPH_SCOPE=https://graph.microsoft.com/.default
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
# Path inside OneDrive to scan for Excel/CSV files (relative to drive root)
ONEDRIVE_FOLDER_PATH=/Reports/Monthly

# ─── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BRONZE_BUCKET=bronze
MINIO_SILVER_BUCKET=silver
MINIO_REGION=us-east-1

# ─── Oracle Database ────────────────────────────────────────────────────────
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_USER=elt_user
ORACLE_PASSWORD=your-oracle-password
ORACLE_SCHEMA=ELT_PIPELINE
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# ─── Apache Airflow ──────────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__WEBSERVER__SECRET_KEY=change-this-in-production-32-chars-min
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs
AIRFLOW_UID=50000

# ─── FastAPI ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4
API_TITLE=ELT Pipeline Data API
API_VERSION=1.0.0
API_CORS_ORIGINS=http://localhost:8501,https://dashboard.company.com

# ─── Streamlit Dashboard ─────────────────────────────────────────────────────
STREAMLIT_API_BASE_URL=http://localhost:8000
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ─── Notifications ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL_FROM=pipeline@company.com
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=pipeline@company.com
SMTP_PASSWORD=smtp-password

# ─── Pipeline Settings ──────────────────────────────────────────────────────
PIPELINE_ENV=development
PIPELINE_LOG_LEVEL=INFO
PIPELINE_MAX_FILE_SIZE_MB=500
PIPELINE_BATCH_SIZE=10000
PIPELINE_RETRY_MAX_ATTEMPTS=3
PIPELINE_RETRY_BACKOFF_SECONDS=30
